APP_ENV=local
APP_VERSION=0.1.0
GIT_SHA=unknown
LOG_LEVEL=INFO
LOG_FORMAT=pretty
LOG_LLM_RAW_OUTPUT=false
LOG_LLM_PREVIEW_CHARS=1800
FRONTEND_ORIGIN=http://localhost:5173

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=startup-radar
NEO4J_DATABASE=neo4j
APPLY_SCHEMA_ON_STARTUP=true

# OpenAI — required for article extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_RETRIES=0
LLM_MAX_CONCURRENCY=3
LLM_TIMEOUT_SECONDS=45
LLM_RETRY_ATTEMPTS=3
LLM_GLEANING_PASSES=1
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_ST_MODEL=Qwen/Qwen3-Embedding
EMBEDDING_SIMILARITY_THRESHOLD=0.88
ENABLE_EMBEDDING_RESOLUTION=true

# MLflow for tracing, tracking, and eval
# Disable with MLFLOW_ENABLED=false.
MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_PUBLIC_URL=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=startup-radar-ingestion
MLFLOW_OPENAI_AUTOLOG=true
MLFLOW_USE_PROMPT_REGISTRY=true
MLFLOW_PROMPT_EXTRACTION_URI=prompts:/article_extraction@champion
MLFLOW_PROMPT_GLEANING_URI=prompts:/article_extraction_gleaning@champion

SCRAPE_TIMEOUT_SECONDS=20
MAX_ARTICLES_PER_INGEST=150
